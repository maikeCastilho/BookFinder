@model IEnumerable<Bookfinder.Models.FavoriteBook>

@{
    ViewData["Title"] = "Livros Favoritados";
}

<div class="container mt-4">
    <h1 class="text-center">Livros Favoritados</h1>
    <p class="text-center text-muted">Veja sua coleção de livros favoritos!</p>

    <ul class="list-group">
        @foreach (var favorite in Model)
        {
            <li class="list-group-item">
                <div class="row">
                    <div class="col-md-2">
                        <img src="@favorite.Cover" alt="@favorite.Title" class="img-fluid" style="height: 150px; object-fit: cover;" />
                    </div>
                    <div class="col-md-10">
                        <h5 class="mb-1 text-primary">@favorite.Title</h5>
                        <p class="mb-1">Autor: @favorite.Author</p>
                        <div class="d-flex justify-content-between">
                            <a href="https://openlibrary.org/works/@favorite.BookKey" class="btn btn-primary btn-sm">Ver Detalhes</a>
                            <form method="post" asp-action="DeleteFavorite" asp-route-bookKey="@favorite.BookKey" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm">Remover</button>
                            </form>
                        </div>
                        <a asp-action="AddReview" asp-route-favoriteBookId="@favorite.Id" class="btn btn-secondary btn-sm mt-2">Adicionar Resenha</a>
                    </div>
                </div>
            </li>
        }
    </ul>
</div>